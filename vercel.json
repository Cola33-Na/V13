            customCategories = [
                { id: 1, column: 'B', value: '中文', label: '中文', enabled: true },
                { id: 2, column: 'B', value: 'English', label: 'English', enabled: true },
                { id: 3, column: 'C', value: 'LastCopy', label: 'LastCopy', enabled: true },
                { id: 4, column: 'D', value: 'Donation', label: 'Donation', enabled: true },
                { id: 5, column: 'E', value: 'Other', label: 'Other', enabled: true }
            ];
        }
        
