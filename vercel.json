        function renderMobileManualList() {
            const listDiv = document.getElementById('mobileManualList');

            if (manualSelectData.length === 0) {
                listDiv.innerHTML = '<div class="empty-list" style="text-align: center; padding: 20px; color: #9e9e9e;">暫無項目<br>在下方輸入添加</div>';
            } else {
