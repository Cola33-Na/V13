                    <span class="sub-label">備用箱</span>
                </button>
            </div>

            <div class="content-area">

                <!-- 1. 圖書查詢 -->
                <div id="panel-search" class="function-block active">
                    <div class="search-layout">
                        <div class="search-main">
                            <div class="block-title">🔍 圖書查詢</div>

                            <div class="control-box">
                                <div class="search-hint">
                                    💡 請輸入14位數條碼進行查詢（例如：12345678912345）
                                </div>

                                <div class="search-box">
                                    <input type="text" id="searchInput" placeholder="請輸入14位數條碼..." autocomplete="off" maxlength="14" inputmode="numeric">
                                    <button class="btn-primary" onclick="searchBook()" id="searchBtn" style="flex: 1;">
                                        查詢
                                    </button>
                                </div>

                                <div id="statusBar" class="status-bar"></div>

                                <div id="results">
                                    <div class="empty-state">
                                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity: 0.3; margin-bottom: 16px;">
                                            <circle cx="11" cy="11" r="8"></circle>
                                            <path d="m21 21-4.35-4.35"></path>
                                        </svg>
                                        <p>請輸入14位數條碼開始查詢</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="search-sidebar desktop-only">
                            <h3>
                                📋 Manual Select
                                <span id="manualCount" style="font-size: 12px; color: #666; font-weight: normal;">(0)</span>
                            </h3>

                            <div class="manual-list" id="manualList">
                                <div class="empty-list">載入中...</div>
                            </div>

                            <div class="manual-input-group">
                                <input type="text" id="newManualItem" placeholder="加入新項目..." onkeypress="if(event.key==='Enter') addManualItem()">
                                <button class="btn-success btn-sm" onclick="addManualItem()">+</button>
                            </div>

                            <div class="manual-actions">
                                <button class="btn-danger btn-sm" onclick="clearManualSelect()">清空全部</button>
                                <button class="btn-secondary btn-sm" onclick="removeLastManual()">移除最後一筆</button>
                            </div>

                            <button class="btn-info btn-sm export-btn" onclick="exportManualSelect()">
                                📥 匯出清單 (CSV)
                            </button>
                        </div>
                    </div>
                </div>

                <!-- 2. 查詢位置 -->
                <div id="panel-location" class="function-block">
                    <div class="panel-content">
                        <div class="block-title">📍 查詢位置</div>

                        <div class="control-box">
                            <div class="search-hint">
                                💡 請輸入14位數條碼查詢存放位置（例如：12345678912345）
                            </div>

                            <div class="search-box">
                                <input type="text" id="locationInput" placeholder="請輸入14位數條碼..." autocomplete="off" maxlength="14" inputmode="numeric">
                                <button class="btn-primary" onclick="searchLocation()" id="locationBtn" style="flex: 1;">
                                    查詢位置
                                </button>
                            </div>

                            <div id="locationStatusBar" class="status-bar"></div>

                            <div id="locationResults">
                                <div class="empty-state">
                                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity: 0.3; margin-bottom: 16px;">
                                        <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                                        <circle cx="12" cy="9" r="2.5"/>
                                    </svg>
                                    <p>請輸入14位數條碼查詢位置</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 3. 顯示設定 -->
                <div id="panel-display" class="function-block">
                    <div class="panel-content">
                        <div class="block-title">⚙️ 顯示設定</div>
                        <div class="control-box">
                            <label style="display: block; margin-bottom: 10px; font-weight: 600;">圖書館顯示數量：</label>
                            <div style="display: flex; gap: 10px; align-items: center;">
                                <input type="number" id="displayLimit" value="100" min="1" max="500" style="width: 150px;">
                                <button class="btn-secondary" onclick="updateDisplayLimit()">套用設定</button>
                            </div>
                            <div style="margin-top: 10px; font-size: 13px; color: #6c757d;">設定查詢結果顯示的圖書館數量上限（預設100筆）</div>
                        </div>
                    </div>
                </div>

                <!-- 4. 單一位置更新 -->
                <div id="panel-single" class="function-block">
                    <div class="panel-content">
                        <div class="block-title">📝 單一位置更新</div>
                        <div class="control-box">
                            <input type="text" id="singleLocation" placeholder="新位置" style="margin-bottom: 10px;">
                            <input type="text" id="singleBookKey" placeholder="14位數條碼" maxlength="14" inputmode="numeric" style="margin-bottom: 10px;">
                            <button class="btn-success" onclick="updateSingleLocation()">更新</button>
                            <div style="margin-top: 10px; font-size: 13px; color: #6c757d;">請輸入新位置及14位數字條碼。按下更新後請留意下方更新日誌。</div>
                        </div>

                        <div class="log-container">
                            <div class="log-header">
                                <span>📋 最近更新日誌（最近50筆）</span>
                                <button class="btn-sm btn-secondary" onclick="clearLogs()">清空日誌</button>
                            </div>
                            <div class="log-list" id="logList">
                                <div class="empty-log">暫無更新記錄</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 5. 批量位置更新 -->
                <div id="panel-batch" class="function-block">
                    <div class="panel-content">
                        <div class="block-title">📋 批量位置更新</div>

                        <div class="batch-status-panel" id="batchStatusPanel">
                            <div style="flex: 1;">
                                <div class="batch-status-indicator">
                                    <div class="status-dot idle" id="statusDot"></div>
                                    <span class="batch-status-text idle" id="statusText">系統狀態：空閒中</span>
                                </div>
                                <div class="batch-status-detail" id="statusDetail" style="display: none;">
                                    <div id="statusMessage"></div>
                                    <div class="batch-progress-bar" id="progressBar" style="display: none;">
                                        <div class="batch-progress-fill" id="progressFill" style="width: 0%"></div>
                                    </div>
                                </div>
                            </div>
                            <div style="display: flex; flex-direction: column; gap: 8px; align-items: flex-end;">
                                <div style="font-size: 12px; color: #6c757d;">
                                    <span id="lastUpdateTime">--</span>
                                </div>
                                <button class="btn-sm btn-secondary" onclick="checkBatchStatus(true)">🔄 立即刷新</button>
                            </div>
                        </div>

                        <div class="control-box">
                            <label style="display: block; margin-bottom: 15px; font-size: 16px; font-weight: 600;">
                                <span style="background: #667eea; color: white; width: 24px; height: 24px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 12px; margin-right: 8px;">3</span>
                                批量更新書目位置
                            </label>
                            <div style="margin-bottom: 15px; padding: 15px; background: #fff3cd; border-radius: 8px; border: 1px solid #ffeaa7;">
                                <label style="font-size: 14px; color: #856404; font-weight: 600; display: block; margin-bottom: 8px;">預設新位置：</label>
                                <input type="text" id="batchDefaultLocation" placeholder="輸入新位置（如：3F-A區）..." style="border-color: #ffeaa7;">
                            </div>
                            <textarea id="batchData" placeholder="格式：14位純數字條碼（每行一筆，位置可選）&#10;系統會自動套用上方預設位置&#10;範例：&#10;12345678901234&#10;12345678901235&#10;12345678901236,特殊位置"></textarea>
                            <div style="display: flex; gap: 10px; margin-top: 15px;">
                                <button class="btn-warning" onclick="clearBatchData()">🗑️ 清空</button>
                                <button class="btn-primary" onclick="submitBatchUpdateAsync()">確認批量更新（異步）</button>
                            </div>
                            <div style="margin-top: 10px; font-size: 13px; color: #6c757d;">
                                💡 提示：提交後立即返回，背景處理中。可透過上方狀態面板查看進度。
                            </div>
                            <div id="batchStatus" class="status-bar" style="margin-top: 15px; display: none;"></div>
                        </div>

                        <div class="error-list-container" id="errorListContainer" style="display: none;">
                            <div class="error-list-header">
                                <span>⚠️ AddNewAddressErr 錯誤記錄</span>
                                <div class="error-list-actions">
                                    <span class="badge badge-danger" id="errorCountBadge">0 筆</span>
                                    <button class="btn-sm btn-info" onclick="exportErrorList()">📥 匯出錯誤</button>
                                    <button class="btn-sm btn-danger" onclick="clearErrorList()" id="clearErrBtn">🗑️ 清空</button>
                                </div>
                            </div>
                            <div class="error-list-content" id="errorListContent">
                                <div class="empty-list">暫無錯誤記錄</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 6. 裝箱功能 (PACKBOX) -->
                <div id="panel-packing" class="function-block">
                    <div class="panel-content" id="packingPanelContent">
                        <div class="block-title" id="packingBlockTitle">
                            <div class="block-title-left">
                                📦 裝箱管理
                                <span class="sheet-badge packbox" id="currentSheetBadge">PACKBOX</span>
                            </div>
                            <div class="block-title-actions">
                                <button class="title-btn title-btn-primary" id="uploadFileBtn" onclick="showUploadModal()">
                                    📤 上傳Excel
                                </button>
                                <button class="title-btn title-btn-secondary" onclick="exportPackingExcel()">
                                    📥 匯出Excel
                                </button>
                                <button class="title-btn title-btn-secondary" onclick="showEditHeadersModal()">
                                    ✏️ 編輯標題
                                </button>
                                <button class="title-btn title-btn-secondary" onclick="clearPackingAll()">
                                    🗑️ 清空
                                </button>
                            </div>
                        </div>

                        <div class="packing-layout">
                            <div class="packing-sidebar" id="packingSidebar">
                                <div class="sidebar-stats" id="sidebarStats" style="display: none;">
                                    <div><span>總資料筆數：</span><span id="statTotal">0</span></div>
                                    <div><span>已分類：</span><span id="statClassified">0</span></div>
                                    <div><span>未分類：</span><span id="statUnclassified">0</span></div>
                                </div>

                                <div class="zone-item active" onclick="filterZone('all', this)">
                                    <span class="zone-name">🏠 全部資料</span>
                                    <span class="zone-count" id="zoneCountAll">0 筆</span>
                                </div>

                                <div id="zoneList"></div>

                                <div class="sidebar-actions">
                                    <button class="btn-success btn-sm" onclick="showAddZoneModal()">➕ 新增位置</button>
                                    <button class="btn-warning btn-sm" onclick="clearPackingLocations()">🗑️ 清理位置</button>
                                </div>
                            </div>

                            <div class="packing-main">
                                <div class="quick-input-area" id="quickInputArea" style="display: none;">
                                    <h4 style="margin-bottom: 10px;">➕ 快速新增到 <span id="currentZoneName"></span></h4>
                                    <div class="quick-input-row">
                                        <input type="text" id="quickKeyInput" placeholder="輸入 A欄 Key 值後按Enter或點擊加入..." autocomplete="off">
                                        <button class="btn-primary quick-add-btn" id="quickAddBtn" onclick="quickAddSearch()">➕ 加入</button>
                                    </div>
                                    <div id="quickSearchResult" style="margin-top: 10px;"></div>
                                </div>

                                <div id="packingSummary">
                                    <div class="summary-grid">
                                        <div class="summary-card">
                                            <h3>📊 各區數量統計</h3>
                                            
                                            <div class="stats-table-container">
                                                <table class="stats-table" id="zoneStatsTable">
                                                    <thead>
                                                        <tr id="statsTableHeaderRow">
                                                            <th>A欄 (位置)</th>
                                                            <th>Quantity<br><span class="stats-table-header-note">總數量</span></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody id="zoneStatsTableBody">
                                                        <tr>
                                                            <td colspan="7" style="text-align: center; padding: 40px; color: #9e9e9e;">
                                                                載入中...
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div id="packingDataList" style="display: none;">
                                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; flex-wrap: wrap; gap: 10px;">
                                        <h3 id="dataListTitle">資料列表</h3>
                                        <button class="btn-secondary btn-sm" onclick="backToSummary()">← 返回總覽</button>
                                    </div>

                                    <div style="margin-bottom: 15px; display: flex; gap: 10px; flex-wrap: wrap;">
                                        <input type="text" id="packingSearchInput" placeholder="搜尋..." style="flex: 1; min-width: 200px;" onkeypress="if(event.key==='Enter') searchPackingData()">
                                        <select id="packingSearchRange" style="width: auto;">
                                            <option value="A">A 欄</option>
                                            <option value="B">B 欄</option>
                                            <option value="C">C 欄</option>
                                            <option value="D">D 欄</option>
                                            <option value="E">E 欄</option>
                                            <option value="F">F 欄</option>
                                        </select>
                                        <button class="btn-primary btn-sm" onclick="searchPackingData()">🔍 搜尋</button>
                                    </div>

                                    <div class="excel-table-container" id="excelTableContainer">
                                        <table class="excel-table" id="excelDataTable">
                                            <thead>
                                                <tr id="tableHeaderRow">
                                                    <th>A(Key)</th>
                                                    <th>B</th>
                                                    <th>C</th>
                                                    <th>D</th>
                                                    <th>E</th>
                                                    <th>F (位置)</th>
                                                    <th>操作</th>
                                                </tr>
                                            </thead>
                                            <tbody id="excelTableBody">
                                            </tbody>
                                        </table>
                                    </div>

                                    <div class="pagination-controls" id="paginationControls" style="display: none;">
                                        <button class="pagination-btn" id="prevPageBtn" onclick="changePage(-1)" disabled>
                                            ← 上一頁
                                        </button>
                                        <span class="pagination-info" id="paginationInfo">
                                            第 1 頁，共 1 頁（每頁 200 筆）
                                        </span>
                                        <button class="pagination-btn" id="nextPageBtn" onclick="changePage(1)" disabled>
                                            下一頁 →
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- 手機端 Manual Select 懸浮按鈕 -->
    <button class="mobile-manual-float-btn" id="mobileManualBtn" onclick="toggleMobileManualModal()" title="Manual Select">
        📋
    </button>

    <!-- 手機端 Manual Select 彈窗 -->
    <div class="mobile-manual-modal" id="mobileManualModal" onclick="closeMobileManualModal(event)">
        <div class="mobile-manual-content" onclick="event.stopPropagation()">
            <div class="mobile-manual-header">
                <span class="mobile-manual-title">📋 Manual Select</span>
                <button class="mobile-manual-close" onclick="closeMobileManualModal()">✕</button>
            </div>

            <div class="mobile-manual-list" id="mobileManualList">
                <div class="empty-list">載入中...</div>
            </div>

            <div class="mobile-manual-input-group">
                <input type="text" id="mobileNewManualItem" placeholder="加入新項目..." onkeypress="if(event.key==='Enter') addMobileManualItem()">
                <button class="btn-success btn-sm" onclick="addMobileManualItem()">+</button>
            </div>

            <div class="mobile-manual-actions">
                <button class="btn-danger btn-sm" onclick="clearMobileManualSelect()">清空全部</button>
                <button class="btn-secondary btn-sm" onclick="removeMobileLastManual()">移除最後</button>
            </div>

            <button class="btn-info btn-sm" onclick="exportMobileManualSelect()" style="width: 100%; margin-top: 10px;">
                📥 匯出清單 (CSV)
            </button>
        </div>
    </div>

    <!-- Modal -->
    <div class="modal-overlay" id="modalOverlay" onclick="closeModal(event)">
        <div class="modal" onclick="event.stopPropagation()">
            <h3 id="modalTitle">標題</h3>
            <div id="modalContent"></div>
            <div class="modal-actions" id="modalActions">
                <button class="btn-secondary" onclick="closeModal()">取消</button>
                <button class="btn-primary" id="modalConfirmBtn" onclick="modalConfirm()">確認</button>
            </div>
        </div>
    </div>

    <!-- 編輯標題 Modal -->
    <div class="modal-overlay header-edit-modal" id="headerEditModalOverlay" onclick="closeHeaderEditModal(event)">
        <div class="modal" onclick="event.stopPropagation()">
            <h3>✏️ 編輯欄位標題與統計分類</h3>
            <div id="headerEditContent">
                <div class="header-edit-grid">
                    <div class="header-edit-item">
                        <label>A 欄 (Key) - 不可修改</label>
                        <input type="text" id="headerInputA" value="A" disabled style="background: #f5f5f5;">
                    </div>
                    <div class="header-edit-item">
                        <label>B 欄</label>
                        <input type="text" id="headerInputB" placeholder="例如：Quantity">
                    </div>
                    <div class="header-edit-item">
                        <label>C 欄</label>
                        <input type="text" id="headerInputC" placeholder="例如：Find">
                    </div>
                    <div class="header-edit-item">
                        <label>D 欄</label>
                        <input type="text" id="headerInputD" placeholder="例如：LastCopy">
                    </div>
                    <div class="header-edit-item">
                        <label>E 欄</label>
                        <input type="text" id="headerInputE" placeholder="例如：Donation">
                    </div>
                    <div class="header-edit-item">
                        <label>F 欄 (位置)</label>
                        <input type="text" id="headerInputF" placeholder="例如：Other">
                    </div>
                </div>
                
                <div class="modal-custom-categories">
                    <h4>📊 自定義統計分類設定 (5個欄位)</h4>
                    <div style="font-size: 12px; color: #666; margin-bottom: 15px; background: #fff3cd; padding: 10px; border-radius: 6px; border-left: 4px solid #ff9800;">
                        💡 設定各區統計表格的5個分類欄位。系統會統計每個位置(F欄)下，指定欄位等於指定值的數量。
                    </div>
                    <div id="headerEditCustomCategories" class="custom-category-grid">
                    </div>
                </div>
                
                <div style="background: #e3f2fd; padding: 12px; border-radius: 8px; font-size: 13px; color: #1976d2; margin-top: 20px;">
                    💡 提示：修改標題只會影響顯示名稱，不會影響實際資料。統計分類設定會影響「各區數量統計」表格的列顯示。
                </div>
            </div>
            <div class="modal-actions">
                <button class="btn-secondary" onclick="closeHeaderEditModal()">取消</button>
                <button class="btn-primary" onclick="saveHeadersAndCategories()">💾 儲存設定</button>
            </div>
        </div>
    </div>

    <!-- Upload Modal -->
    <div class="modal-overlay upload-modal-overlay" id="uploadModalOverlay" onclick="closeUploadModal(event)">
        <div class="modal" onclick="event.stopPropagation()" style="text-align: center;">
            <h3 id="uploadModalTitle" style="text-align: left;">📤 上傳 Excel 檔案</h3>

            <div class="upload-modal-content">
                <input type="file" id="modalFileInput" accept=".xlsx,.xls" onchange="handleModalFileSelect(event)" style="display: none;">
                <label for="modalFileInput" class="upload-area" id="modalUploadArea" style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 220px; margin: 20px 0;">
                    <div class="upload-icon">📁</div>
                    <div style="font-weight: 600; font-size: 18px; margin-bottom: 8px;">點擊選擇 Excel 檔案</div>
                    <div class="upload-hint" style="font-size: 13px; color: #888; line-height: 1.6;">
                        支援格式：.xlsx, .xls<br>
                        A-F欄位對應：A=Key, B-E=資料, F=位置（可留空）<br>
                        檔案大小限制：5MB
                    </div>
                </label>

                <div id="uploadFileInfo" style="display: none; margin: 15px 0; padding: 15px; background: #e8f5e9; border-radius: 8px; border-left: 4px solid #28a745; text-align: left;">
                    <div style="font-weight: 600; color: #2e7d32; font-size: 14px;">✅ 已選擇檔案：<span id="selectedFileName"></span></div>
                </div>

                <div class="upload-progress-container" id="uploadProgressContainer">
                    <div class="upload-progress-bar" id="uploadProgressBar">0%</div>
                </div>
                <div class="upload-status-text" id="uploadStatusText"></div>

