        async function addMobileManualItem() {
            const input = document.getElementById('mobileNewManualItem');
            const value = input.value.trim();
            if (!value) return;

            if (!manualSelectData.includes(value)) {
                manualSelectData.push(value);
                renderManualList();
                renderMobileManualList();
                input.value = '';
            }

            try {
                await libraryApiCall('addToManualSelect', { value: value });
            } catch (e) {
                console.error('背景同步失敗:', e);
            }
        }

        async function removeMobileManualItem(value, index) {
            manualSelectData.splice(index, 1);
            renderManualList();
            renderMobileManualList();

            try {
                await libraryApiCall('removeFromManualSelect', { value: value });
            } catch (e) {
                console.error('背景同步失敗:', e);
            }
        }

        async function removeMobileLastManual() {
            if (manualSelectData.length === 0) return;
            const lastItem = manualSelectData[manualSelectData.length - 1];

            manualSelectData.pop();
            renderManualList();
            renderMobileManualList();

            try {
                await libraryApiCall('removeFromManualSelect', { value: lastItem });
            } catch (e) {
                console.error('背景同步失敗:', e);
            }
        }

        async function clearMobileManualSelect() {
            if (!confirm('確定清空全部 Manual Select 項目？')) return;

            manualSelectData = [];
            renderManualList();
            renderMobileManualList();

            try {
                await libraryApiCall('clearManualSelect');
            } catch (e) {
                console.error('清空失敗:', e);
            }
