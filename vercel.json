        //================ API 呼叫函數（含重試機制） =================
        async function libraryApiCall(action, params = {}, timeout = 60000) {
            return apiCallWithRetry(LIBRARY_API_URL, action, params, timeout, 3);
        }
        
        async function packingApiCall(action, params = {}, timeout = 60000) {
            return apiCallWithRetry(PACKING_API_URL, action, params, timeout, 3);
        }
        
        async function apiCallWithRetry(baseUrl, action, params, timeout, maxRetries) {
            let lastError;
            
            for (let attempt = 1; attempt <= maxRetries; attempt++) {
                try {
                    const result = await executeApiCall(baseUrl, action, params, timeout);
                    return result;
                } catch (error) {
                    lastError = error;
                    console.warn(`API呼叫失敗 (嘗試 ${attempt}/${maxRetries}): ${error.message}`);
                    
                    if (attempt < maxRetries) {
                        const delay = Math.min(1000 * Math.pow(2, attempt - 1), 5000);
                        await new Promise(resolve => setTimeout(resolve, delay));
                    }
                }
            }
            
            throw new Error(`請求失敗（已重試${maxRetries}次）: ${lastError.message}`);
        }

        function executeApiCall(baseUrl, action, params, timeout) {
            return new Promise((resolve, reject) => {
                const callbackName = 'api_cb_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9);
                const script = document.createElement('script');

                const queryParams = new URLSearchParams({
                    action: action,
                    callback: callbackName,
                    ...params
                });

                const url = `${baseUrl}?${queryParams.toString()}`;

                const timeoutId = setTimeout(() => {
                    cleanup();
                    reject(new Error('請求超時'));
                }, timeout);

                function cleanup() {
                    clearTimeout(timeoutId);
                    if (script.parentNode) script.parentNode.removeChild(script);
                    delete window[callbackName];
                }

                window[callbackName] = (data) => {
                    cleanup();
                    resolve(data);
                };

                script.onerror = () => {
                    cleanup();
                    reject(new Error('載入失敗'));
                };

                script.src = url;
                document.head.appendChild(script);
            });
        }

