                try {
                    const parsed = JSON.parse(saved);
                    if (parsed.length === 5) {
                        customCategories = parsed;
                    } else {
                        resetCustomCategories();
                    }
                } catch (e) {
                    console.error('載入自定義分類失敗:', e);
